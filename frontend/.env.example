VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production

# Local dev (default if unset). For production: set to your deployed Studio URL
# so Presentation mode / visual editing can connect (e.g. https://your-project.sanity.studio)
VITE_SANITY_STUDIO_URL=http://localhost:3333

# Backend API base URL. Leave empty in production to call the API same-origin
# via the /api rewrite (see vercel.json). Set explicitly for cross-origin dev,
# e.g. VITE_API_BASE_URL=http://localhost:5001
VITE_API_BASE_URL=

# Google Calendar appointment-schedule link used by the booking modal.
VITE_GOOGLE_BOOKING_URL=

# Canonical production site URL — used to build sitemap.xml, robots.txt, and
# canonical/OG tags at build time. MUST be set in the production build env or
# the sitemap falls back to https://example.com.
VITE_SITE_URL=https://arh.panta.llc

# Google Analytics 4 Measurement ID to enable analytics (no-ops if unset, so
# dev/preview send no traffic). Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

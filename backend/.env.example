PORT=5000
MONGODB_URI=your_mongodb_connection_string
# Allowed browser origin(s) for CORS. Single value for dev; comma-separated
# list for production (apex + www so both resolve), no trailing slashes, e.g.
# CORS_ORIGIN=https://ariellehastings.com,https://www.ariellehastings.com
CORS_ORIGIN=http://localhost:5173
SANITY_PROJECT_ID=your_sanity_project_id
SANITY_DATASET=production

# Optional: send consultation form submissions as email to practitioner
# PRACTITIONER_EMAIL=you@example.com
# Either set MAILER_URL (e.g. smtps://user:pass@smtp.gmail.com:465) or SMTP_*:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# MAIL_FROM=noreply@yourdomain.com
